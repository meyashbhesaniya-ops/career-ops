# Generate a random token on first run — shown in console
BRIDGE_TOKEN=
# Paste your Chrome extension ID here (from chrome://extensions)
ALLOWED_EXTENSION_ID=
# Gemini API key (shared with parent repo .env)
GEMINI_API_KEY=
# Groq API key (for vision-based field detection)
GROQ_API_KEY=
# Port (default 8787)
PORT=8787
