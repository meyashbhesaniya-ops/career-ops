# career-ops AutoApply System — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to git.
#
# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://lqrdynownccyjyfpuejc.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:[password]@db.lqrdynownccyjyfpuejc.supabase.co:5432/postgres

# ── Telegram ──────────────────────────────────────────────────────────────────
# REVOKE THE OLD TOKEN AT @BotFather FIRST, then paste new one here
TELEGRAM_BOT_TOKEN=your_new_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here

# ── Vault encryption key ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VAULT_KEY=6c76e3f369b2b96d4f280471cab544ac66fd7798f9fa00a263d5eb448be7effa

# ── LLM APIs ──────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── GitHub ────────────────────────────────────────────────────────────────────
# PAT with repo + actions:write scope
GITHUB_PAT=your_github_personal_access_token_here
GITHUB_REPO=santifer/career-ops
# Secret shared between orchestrator and GitHub Actions webhook
GH_WEBHOOK_SECRET=your_random_webhook_secret_here

# ── Oracle Cloud ──────────────────────────────────────────────────────────────
OCI_TENANCY_OCID=ocid1.tenancy.oc1..aaaaaaaapla6jzhzygcbngduihbqml6emmntcptlrscsiucarclteh6z2wbq
OCI_USER_OCID=ocid1.user.oc1..your_user_ocid_here
OCI_FINGERPRINT=your_api_key_fingerprint_here
OCI_PRIVATE_KEY_PATH=/home/ubuntu/.oci/oci_api_key.pem
OCI_REGION=eu-frankfurt-1

# ── Agent endpoints ───────────────────────────────────────────────────────────
# On Micro #0 — used by tailor (on Micro #1) to call orchestrator
ORCHESTRATOR_URL=http://89.168.115.96:9000
ORCHESTRATOR_PORT=9000
ORCHESTRATOR_TOKEN=your_random_orchestrator_token_here

# On Micro #1 — used by orchestrator (on Micro #0) to call tailor
TAILOR_URL=http://130.162.209.192:9001
TAILOR_PORT=9001
TAILOR_TOKEN=your_random_tailor_token_here

# Evaluator (on Micro #0, localhost)
EVALUATOR_URL=http://localhost:9002
EVALUATOR_PORT=9002
